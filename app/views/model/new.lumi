{% layout 'model/base' %}

{% block buttons %}
    <button onclick="location.href = '{! route('model.index') | escape_js !}';">Back</button>
{% endblock %}

{% block content %}
    <form action="{! route() | escape_attr !}" method="post">
        <strong>Name</strong>: <input type="text" name="name">
        <input type="submit" value="Create">
    </form>
{% endblock %}